<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://xmlns.jcp.io/xml/ns/javaee"
         xsi:schemaLocation="http://xmlns.jcp.io/xml/ns/javaee http://xmlns.jcp.io/xml/ns/javaee/web-app_4_0.xsd"
         id="WebApp_ID" version="4.0">

  <display-name>Smart Consumer</display-name>

  <!-- Character Encoding Filter -->
  <filter>
    <filter-name>encodingFilter</filter-name>
    <filter-class>dev.smartconsumer.filter.EncodingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>encodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- Welcome File -->
  <welcome-file-list>
    <welcome-file>login.jsp</welcome-file>
  </welcome-file-list>

  <!-- Session Timeout (minutes) -->
  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>
</web-app>